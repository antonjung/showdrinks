{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log"]
    }
  ],
  "hosting": {
    "predeploy": ["node bump-version.js"],
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "firestore.indexes.json",
      "bump-version.js",
      "README.md",
      "node_modules/**",
      ".git/**",
      ".gitignore",
      "CLAUDE.md",
      "functions/**"
    ]
  }
}
